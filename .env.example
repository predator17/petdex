# petdex env vars.
#
# TWO SUPPORTED PATHS to run locally:
#
#   1. bun run dev:docker   - Postgres + Redis in containers + shared OSS Clerk.
#                             Good for testing DB queries, auth flows, or anything
#                             that touches a real backend. Defaults are committed
#                             in .env.dev — copy any value here only if you want
#                             to override it for yourself.
#
#   2. bun run dev          - your own everything. For maintainers.
#                             Fill in the values below from your private accounts.
#
# Anything you set in .env.local wins over .env.dev. Most contributors
# never need to touch this file.

# Core
DATABASE_URL=

# Clerk (frontend public, backend secret)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=
PETDEX_MANIFEST_V1_URL=
PETDEX_MANIFEST_V1_SNAPSHOT_KEY=
PETDEX_MANIFEST_V2_URL=
PETDEX_MANIFEST_V2_SNAPSHOT_KEY=
PETDEX_COLLECTION_PREVIEWS_URL=
PETDEX_COLLECTION_PREVIEWS_SNAPSHOT_KEY=

# Lightweight animated card previews (cropped idle-row strip per pet).
# Off by default: only flip to "true" after running `bun previews:snapshot:apply`
# so cards never point at a preview that doesn't exist yet in R2.
NEXT_PUBLIC_PETDEX_PET_PREVIEWS_ENABLED=

# AI / similarity / review / autotag / sound
# Embeddings and automated review use Vercel AI Gateway via AI SDK.
AI_GATEWAY_API_KEY=
ELEVENLABS_API_KEY=
FFMPEG_BIN=

# Redis / rate-limit / cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: explicit per-deployment secret used to hash IPs in the
# /api/telemetry/event rate limiter. If unset, we derive from
# UPSTASH_REDIS_REST_TOKEN (also deploy-stable). The route throws at
# module load in production if NEITHER is set, since per-process
# fallbacks would multiply the 60/min ingestion limit by the number
# of active serverless instances.
TELEMETRY_RATELIMIT_SECRET=
PETDEX_ROUTE_COST_SECRET=
PETDEX_ROUTE_COST_SAMPLE_RATE=

# Shared secret for POST /api/revalidate. External writers that share the
# DB/Upstash (admin.petdex.dev) call it to flush this app's Next data
# cache tags after approve/reject/edit. Must match the admin app's value.
PETDEX_REVALIDATE_SECRET=

# Optional: lets /api/revalidate also purge the Cloudflare edge cache for
# pet URLs. Cloudflare fronts petdex.dev with a cache-everything rule that
# holds 404/500 HTML for ~1h after the origin is fixed. Token needs
# Zone.Cache Purge on the petdex.dev zone.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PURGE_TOKEN=

# Email notifications
RESEND_API_KEY=
RESEND_FROM=
PETDEX_OWNER_EMAIL=
PETDEX_ADMIN_NOTIFY_EMAIL=

# Admin
PETDEX_ADMIN_USER_IDS=
NEXT_PUBLIC_PETDEX_ADMIN_USER_IDS=
PETDEX_ADMIN_URL=https://admin.petdex.dev
NEXT_PUBLIC_PETDEX_ADMIN_URL=https://admin.petdex.dev

# Optional app URLs
PETDEX_ALL_PETS_PACK_URL=
VERCEL_URL=
PETDEX_URL=

# Community
# Enables the Discord CTA and /community page when set.
NEXT_PUBLIC_DISCORD_INVITE_URL=
# Enables the zh-only WeChat CTA when set to 1. Requires the Aliyun OSS
# server envs below because the QR is served through /api/wechat-qr.
NEXT_PUBLIC_WECHAT_COMMUNITY_ENABLED=

# Aliyun OSS credentials for /api/wechat-qr and QR rotation.
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=

# CLI / script-related
CLERK_CLI_ISSUER=
PETDEX_CLERK_APP=
PETDEX_CLERK_INSTANCE=
CLERK_ISSUER=
CLERK_OAUTH_CLIENT_ID=

# In-app pet generation (Workstream C). Used only by scripts/run-desktop.ts
# and scripts/setup-windows.ts to write the key to the LOCAL sidecar key
# store (~/.petdex/runtime/openrouter-key). NEVER sent to the petdex
# backend. Get one at https://openrouter.ai/keys. gpt-image-2 is the only
# allowed model (mandatory; no fallback). Cost: ~$0.40/pet, max ~$0.80.
OPENROUTER_API_KEY=
